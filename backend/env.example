GEMINI_API_KEY=

# Match docker-compose.dev.yml (Postgres). From repo root:
# docker compose -f docker-compose.dev.yml --env-file backend/.env up -d
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# Clerk (Next.js)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk JWT verification for Django API (Dashboard → API keys → JWKS URL)
# Example: https://your-subdomain.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=
# Optional: must match JWT `iss` if verification fails without it
# CLERK_JWT_ISSUER=

# Clerk webhooks (Django) — signing secret from Dashboard → Webhooks → Endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=


CLERK_SECRET_KEY


CLERK_JWKS_URL=
CLERK_JWT_ISSUER=


